{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build -- --filter=@nepalens/web"
  },
  "deploy": {
    "startCommand": "cd apps/web && node_modules/.bin/next start -H 0.0.0.0 -p ${PORT:-3000}",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
